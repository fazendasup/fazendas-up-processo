# ============================================================
# Fazendas Up — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database Connection
# Examples:
#   MySQL:      mysql://user:password@localhost:3306/fazendas_up
#   PostgreSQL: postgresql://user:password@localhost:5432/fazendas_up
#   SQLite:     file:./fazendas_up.db
DATABASE_URL=mysql://user:password@localhost:3306/fazendas_up

# JWT Secret for session cookie signing
# Generate a strong random string (min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Node Environment
# Options: development, production
NODE_ENV=development

# Server Port (optional, defaults to 3000)
# PORT=3000
